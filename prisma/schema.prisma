generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Screen {
  id        String   @id @db.VarChar(64)
  createdAt DateTime @default(now())
  bmiData   BMI[]
}

model AdscapePlayer {
  id                       String   @id @default(uuid()) @db.Uuid
  screenId                 String   @unique @db.VarChar(64)
  appVersion               String   @db.VarChar(10)
  flowType                 String?  @db.VarChar(10)
  deviceName               String?  @db.VarChar(255)
  screenWidth              Int?
  screenHeight             Int?
  ipAddress                String?  @db.VarChar(45)
  location                 String?  @db.VarChar(255)
  osVersion                String?  @db.VarChar(50)
  appVersionCode           String?  @db.VarChar(20)
  heightCalibration        Float?   @default(0)
  paymentAmount            Float?
  logoUrl                  String?
  playlistId               String?  @db.VarChar(255)
  flowDrawerEnabled        Boolean? @default(true)
  flowDrawerSlotCount      Int?     @default(2)
  hideScreenId             Boolean? @default(false)
  hideAppMargin            Boolean? @default(false)
  smsEnabled               Boolean? @default(false)
  smsLimitPerScreen        Int?
  smsSentCount             Int?     @default(0)
  whatsappEnabled          Boolean? @default(false)
  whatsappLimitPerScreen   Int?
  whatsappSentCount        Int?     @default(0)
  flowDrawerSlots          Json?
  flowDrawerImage1Url      String?
  flowDrawerImage2Url      String?
  flowDrawerImage3Url      String?
  flowDrawerImage4Url      String?
  flowDrawerImage5Url      String?
  lastSeen                 DateTime @default(now())
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  heightCalibrationEnabled Boolean? @default(true)
  defaultAssetUrl          String?  @db.VarChar(500)
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  gender    String?  @db.VarChar(10)
  age       Int?
  mobile    String   @db.VarChar(20)
  createdAt DateTime @default(now())
  bmiData   BMI[]
}

model BMI {
  id            String   @id @db.Uuid
  screenId      String
  userId        String?  @db.Uuid
  heightCm      Float
  weightKg      Float
  bmi           Float
  category      String
  timestamp     DateTime @default(now())
  deviceId      String?  @db.VarChar(255)
  appVersion    String?  @db.VarChar(10)
  location      String?  @db.VarChar(255)
  fortune       String?
  healthTip     String?
  paymentStatus Boolean? @default(false)
  paymentAmount Float?
  screen        Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])

  @@index([screenId])
  @@index([userId])
  @@index([userId, timestamp])
}

model AdminUser {
  id                 String                  @id @default(uuid()) @db.Uuid
  email              String                  @unique @db.VarChar(255)
  password           String                  @db.VarChar(255)
  name               String                  @db.VarChar(255)
  role               String                  @db.VarChar(20)
  totalMessageLimit  Int?
  totalWhatsAppLimit Int?
  smsUsedCount       Int?                    @default(0)
  whatsappUsedCount  Int?                    @default(0)
  isActive           Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  assignedScreens    AdminScreenAssignment[]

  @@index([email])
  @@index([role])
}

model AdminScreenAssignment {
  id            String    @id @default(uuid()) @db.Uuid
  adminId       String    @db.Uuid
  screenId      String    @db.VarChar(64)
  messageLimit  Int?
  whatsappLimit Int?
  createdAt     DateTime  @default(now())
  admin         AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, screenId])
  @@index([adminId])
  @@index([screenId])
}

model media {
  id         String    @id @db.VarChar(36)
  name       String    @db.VarChar(255)
  type       String    @db.VarChar(20)
  path       String    @db.VarChar(512)
  url        String
  size       BigInt?
  format     String?   @db.VarChar(20)
  duration   Float?
  created_by String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamp(6)
  tags       String?

  @@index([created_by], map: "idx_media_created_by")
  @@index([type], map: "idx_media_type")
}

model playlists {
  id          String    @id @db.VarChar(255)
  name        String    @db.VarChar(255)
  description String?
  tags        String?
  slots       String?
  created_by  String?   @db.Uuid
  created_at  DateTime? @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)

  @@index([created_by], map: "idx_playlists_created_by")
}

model schedules {
  id          String    @id @db.VarChar(255)
  name        String    @db.VarChar(255)
  description String?
  events      String?
  status      String?   @default("active") @db.VarChar(50)
  created_at  DateTime? @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)
}

model screen_playlists {
  screen_id   String    @id @db.VarChar(64)
  playlist_id String?   @db.VarChar(255)
  start_date  DateTime? @db.Timestamp(6)
  end_date    DateTime? @db.Timestamp(6)
  assigned_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
}
